---
import entries from "../../public/data.json" with { type: "json" };
const dataJson = JSON.stringify(entries);
---

<header class="relative max-w-5xl mx-auto px-6 pt-12 sm:pt-16 pb-4 sm:pb-6">
  <!-- Decorative minimap strip -->
  <div
    id="minimap"
    class="absolute top-0 left-6 right-6 h-62 sm:h-74 bg-gray-100 rounded-b-2xl overflow-hidden z-0"
    transition:persist
  ></div>

  <!-- Logo and navigation -->
  <div class="relative z-10 text-center mb-8">
    <div
      class="inline-flex flex-col items-center bg-brand-slate rounded-3xl px-8 sm:px-12 py-4 sm:py-6 shadow-xl overflow-visible"
      transition:persist="logo"
    >
      <a
        href="/"
        class="inline-flex items-baseline no-underline font-extrabold text-[90px] sm:text-[110px] leading-none text-[#F8FAFC]"
        style="font-family:Arial,Helvetica,sans-serif;"
        aria-label="Homepage"
      ><span class="text-[#FED911]">/</span>brag</a>
      <nav class="flex gap-x-6 text-base font-medium pt-8 pb-1" aria-label="Main navigation">
        <a href="/" class="text-[#F8FAFC]/70 hover:text-[#F8FAFC] transition-colors no-underline">About</a>
        <a href="/directory" class="text-[#F8FAFC]/70 hover:text-[#F8FAFC] transition-colors no-underline">Directory</a>
        <a href="/how-to-add-your-page" class="text-[#F8FAFC]/70 hover:text-[#F8FAFC] transition-colors no-underline">Submit</a>
      </nav>
    </div>
  </div>

  <slot />
</header>

<script type="application/json" id="__data__" set:html={dataJson}></script>
