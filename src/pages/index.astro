---
import Header from "../components/Header.astro";
import entries from "../../public/data.json" with { type: "json" };
import mapJs from "../map.js?raw";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

// compute stats from embedded data
const US_STATES = new Set(
	"AL AK AZ AR CA CO CT DE FL GA HI ID IL IN IA KS KY LA ME MD MA MI MN MS MO MT NE NV NH NJ NM NY NC ND OH OK OR PA RI SC SD TN TX UT VT VA WA WV WI WY DC".split(
		" ",
	),
);
const CA_PROVINCES = new Set(
	"AB BC MB NB NL NS ON PE QC SK NT NU YT".split(" "),
);
function country(loc) {
	if (!loc) return "Unknown";
	const parts = loc.split(",");
	const last = parts[parts.length - 1].trim();
	if (US_STATES.has(last)) return "United States";
	if (CA_PROVINCES.has(last)) return "Canada";
	if (
		last === "UK" ||
		last === "England" ||
		last === "Scotland" ||
		last === "Wales"
	)
		return "United Kingdom";
	if (last === "UAE") return "United Arab Emirates";
	if (last === "Newfoundland" || last === "Newfoundland and Labrador")
		return "Canada";
	return last;
}
const countrySet = new Set();
for (const e of entries) countrySet.add(country(e.location));
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>/brag</title>
  <meta name="description" content="/brag is a directory of personal achievement pages. Be proud of what you've done." />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📄</text></svg>" />
  <link rel="stylesheet" href="/leaflet.css" />
  <ClientRouter />
</head>
<body class="bg-[#fafaf5] antialiased">

  <Header>
    <div class="max-w-2xl mx-auto bg-white rounded-2xl shadow-md relative z-10 overflow-hidden mb-10">
      <div class="px-6 sm:px-10 pt-8 sm:pt-10 pb-7 sm:pb-8">
        <p class="text-lg sm:text-xl text-gray-900 leading-snug font-semibold tracking-tight">
           Nobody talks about their wins enough. A <strong>/brag</strong> page is where you do exactly that. 
        </p>
        <p class="mt-3 text-sm sm:text-base text-gray-700 leading-relaxed">
          A seamless, format-free space to track everything you're proud of, from shipped projects to personal wins.
        </p>
        <p class="mt-5 text-sm text-gray-700">
          <strong class="font-semibold text-gray-900">{entries.length}</strong> entries from
          <strong class="font-semibold text-gray-900">{countrySet.size}</strong> countries and counting
        </p>
        <div class="mt-6 flex justify-center">
          <a href="/directory"
             class="inline-flex items-center gap-2 bg-[#FED911] hover:bg-[#e6c400] text-[#1E293B] font-semibold px-6 py-3 rounded-xl transition-all duration-200 hover:-translate-y-px hover:shadow-lg shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#FED911] focus-visible:ring-offset-2">
            See what people are proud of
            <span class="text-lg leading-none">→</span>
          </a>
        </div>
      </div>

      <div class="border-t border-gray-100 px-6 sm:px-10 py-5 sm:py-6">
        <p class="text-xs font-medium uppercase tracking-wider mb-3">What belongs in a /brag page</p>
        <div class="flex flex-wrap gap-2">
          {["Projects", "Presentations", "Open Source", "Blog posts", "Promotions", "Mentoring wins", "Awards", "Personal wins", "Hard problems"].map(item => (
            <span class="text-sm text-gray-600 bg-gray-50 rounded-full px-3 py-1">{item}</span>
          ))}
        </div>
      </div>
    </div>
  </Header>

  <footer class="max-w-5xl mx-auto text-left py-9 px-6 text-base text-gray-500 w-full">
    <p>
      Want to add yours?
      <a href="/how-to-add-your-page" class="text-[#1E293B] font-semibold hover:underline">Submit a PR →</a>
      <span class="mx-2 text-gray-300">|</span>
      An idea by <a href="https://mostlytechnical.com/" class="text-[#1E293B] font-semibold hover:underline">MostlyTechnical</a>,
      built by <a href="https://alexgaudon.dev" class="text-[#1E293B] font-semibold hover:underline">Alex Gaudon</a>
    </p>
  </footer>

  <script is:inline defer src="/leaflet.js"></script>
  <script is:inline set:html={mapJs}></script>
</body>
</html>
