---
import Header from '../components/Header.astro';
import entries from '../../public/data.json' with { type: 'json' };
import mapJs from '../map.js?raw';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

// compute stats from embedded data
const US_STATES = new Set("AL AK AZ AR CA CO CT DE FL GA HI ID IL IN IA KS KY LA ME MD MA MI MN MS MO MT NE NV NH NJ NM NY NC ND OH OK OR PA RI SC SD TN TX UT VT VA WA WV WI WY DC".split(" "));
const CA_PROVINCES = new Set("AB BC MB NB NL NS ON PE QC SK NT NU YT".split(" "));
function country(loc) {
  if (!loc) return "Unknown";
  const parts = loc.split(",");
  const last = parts[parts.length - 1].trim();
  if (US_STATES.has(last)) return "United States";
  if (CA_PROVINCES.has(last)) return "Canada";
  if (last === "UK" || last === "England" || last === "Scotland" || last === "Wales") return "United Kingdom";
  if (last === "UAE") return "United Arab Emirates";
  if (last === "Newfoundland" || last === "Newfoundland and Labrador") return "Canada";
  return last;
}
const countrySet = new Set();
for (const e of entries) countrySet.add(country(e.location));
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>/brag</title>
  <meta name="description" content="/brag is a directory of personal achievement pages. Be proud of what you've done." />
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📄</text></svg>" />
  <link rel="stylesheet" href="/leaflet.css" />
  <ClientRouter />
</head>
<body class="bg-[#fafaf5] antialiased">

  <Header>
    <!-- Hero card -->
    <div class="max-w-2xl mx-auto bg-white rounded-2xl shadow-md relative z-10">
      <div class="p-6 sm:p-8 text-center">
        <p class="text-lg sm:text-xl text-gray-800 leading-relaxed font-medium">
          Nobody talks about their wins enough. A <strong>/brag</strong> page is where you do exactly that.
        </p>
        <p class="mt-3 text-base text-gray-700 leading-relaxed">
          Just a running list of stuff you're proud of. Projects, talks, bugs you killed,
          promotions, marathons — whatever counts. No rules, no format. Add to it whenever.
        </p>
        <div class="mt-5 flex gap-6 justify-center text-base text-gray-800">
          <span><strong>{entries.length}</strong> entries across <strong>{countrySet.size}</strong> countries and counting</span>
        </div>
        <div class="mt-6">
          <a href="/directory"
             class="inline-flex items-center gap-2 bg-[#FED911] hover:bg-[#e6c400] text-[#1E293B] font-semibold px-6 py-3 rounded-xl transition-all duration-200 hover:-translate-y-px hover:shadow-lg shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#FED911] focus-visible:ring-offset-2">
            See what people are proud of
            <span class="text-lg leading-none">→</span>
          </a>
        </div>
      </div>
    </div>
  </Header>

  <section class="max-w-5xl mx-auto px-6 mb-10">
    <div class="bg-white rounded-2xl p-6 sm:p-8 max-w-2xl mx-auto shadow-md">
      <h3 class="text-base font-bold uppercase tracking-wider text-gray-500 mb-4">What belongs in a /brag page</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-2 text-base text-gray-700">
        <div class="flex items-center gap-2"><span class="text-[#FED911] text-xs">◆</span> Projects</div>
        <div class="flex items-center gap-2"><span class="text-[#FED911] text-xs">◆</span> Presentations</div>
        <div class="flex items-center gap-2"><span class="text-[#FED911] text-xs">◆</span> Open Source</div>
        <div class="flex items-center gap-2"><span class="text-[#FED911] text-xs">◆</span> Blog posts</div>
        <div class="flex items-center gap-2"><span class="text-[#FED911] text-xs">◆</span> Promotions</div>
        <div class="flex items-center gap-2"><span class="text-[#FED911] text-xs">◆</span> Mentoring wins</div>
        <div class="flex items-center gap-2"><span class="text-[#FED911] text-xs">◆</span> Awards</div>
        <div class="flex items-center gap-2"><span class="text-[#FED911] text-xs">◆</span> Personal wins</div>
        <div class="flex items-center gap-2"><span class="text-[#FED911] text-xs">◆</span> Hard problems</div>
      </div>
    </div>
  </section>

  <footer class="text-center py-9 px-6 text-base text-gray-500">
    <p>
      Want to add yours?
      <a href="/how-to-add-your-page" class="text-[#1E293B] font-semibold hover:underline">Submit a PR →</a>
      <span class="mx-2 text-gray-300">|</span>
      An idea by <a href="https://mostlytechnical.com/" class="text-[#1E293B] font-semibold hover:underline">MostlyTechnical</a>,
      built by <a href="https://alexgaudon.dev" class="text-[#1E293B] font-semibold hover:underline">Alex Gaudon</a>
    </p>
  </footer>

  <script is:inline defer src="/leaflet.js"></script>
  <script is:inline set:html={mapJs}></script>
</body>
</html>
